{
  "db_name": "PostgreSQL",
  "query": "\n        select\n            s.id as \"spot_id!\",\n            m.id as \"measure_id!\",\n            s.title,\n            s.latitude,\n            s.longitude,\n            m.collaborator_id,\n            m.created_at,\n            m.items_per_m2,\n            m.weight,\n            m.area,\n            m.pet,\n            m.pead,\n            m.pebd,\n            m.pvc,\n            m.pp,\n            m.ps,\n            m.pa,\n            m.other,\n            m.ihr_plata,\n            m.ibirp\n        from spots s\n        join lateral (\n            select *\n            from measures\n            where spot_id = s.id\n            order by created_at desc\n            limit 1\n        ) m on true\n        order by s.title asc\n        ",
